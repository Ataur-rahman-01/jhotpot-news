FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Default entrypoint. Cloud Run Jobs override args per job:
#   Group A:  python -m scraper.main --group a
#   Group B:  python -m scraper.main --group b
#   Archive:  python -m archive.archiver --mode size-check
ENTRYPOINT ["python"]
CMD ["-m", "scraper.main", "--group", "all"]
